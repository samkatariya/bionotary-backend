# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local dev: if nothing listens on 5432, run `docker compose up -d` in this repo
# and keep these values in sync with docker-compose.yml.
DB_USER=postgres
DB_HOST=localhost
DB_NAME=bionotary
DB_PASSWORD=postgres
DB_PORT=5433

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: comma-separated origins for CORS (omit or empty = reflect request origin in dev)
# ALLOWED_ORIGINS=http://192.168.1.10,http://raspberrypi.local

# On-chain notarization verification (recommended for production).
# If ETH_RPC_URL or BIONOTARY_CONTRACT_ADDRESS is missing, the API still stores the
# notarization but sets verified_on_chain: false (client-trusted MVP).
ETH_RPC_URL=https://rpc.sepolia.org
BIONOTARY_CONTRACT_ADDRESS=0xCDa82472BD768156A5d961A0Ce61d9C93D4ffDA1

# Fingerprint helper (bind mock/real service to 127.0.0.1 only on Pi)
FINGERPRINT_SERVICE_URL=http://127.0.0.1:8765
FP_SERIAL_PORT=/dev/ttyAMA0
FP_BAUD_RATE=57600
FP_SENSOR_ADDR=0xFFFFFFFF
FP_SENSOR_PASS=0x00000000
FP_DB_FILE=fingerprint/fingerprint_db.json

# Mock fingerprint demo: if set, /v1/verify always returns this template_id (for testing without hardware)
# MOCK_FINGERPRINT_VERIFY_TEMPLATE_ID=1
