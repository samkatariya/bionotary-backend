[Unit]
Description=BioNotary Express API
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/bionotary-backend
EnvironmentFile=/opt/bionotary-backend/.env
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
